{
  "name": "simple-jwt-login-website",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "validate-openapi": "swagger-cli validate openapi/build.yaml",
    "gen-openapi": "swagger-cli bundle openapi/build.yaml --outfile static/openapi.yaml --type yaml",
    "gen-api": "docusaurus clean-api-docs all && docusaurus gen-api-docs all",
    "build-api": "yarn run gen-openapi && yarn gen-api",
    "spellcheck": "cspell --config .cspell.json 'docs/**/*.{md,mdx}' 'blog/**/*.md' 'releases/**/*.md' 'src/**/*.{jsx,tsx,ts}'"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/plugin-sitemap": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@mdx-js/react": "^3.1.1",
    "@signalwire/docusaurus-plugin-llms-txt": "^1.2.2",
    "clsx": "^2.0.0",
    "docusaurus-plugin-dotenv": "^1.0.1",
    "docusaurus-plugin-openapi-docs": "^4.7.1",
    "docusaurus-theme-openapi-docs": "^4.7.1",
    "docusaurus2-dotenv": "^1.4.0",
    "path-browserify": "^1.0.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "cspell": "^8.0.0",
    "swagger-cli": "^4.0.4",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=19.0"
  }
}
